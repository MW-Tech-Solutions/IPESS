<script>
// Enhanced JS for interactions
function viewApplication(id) {
    // AJAX to view application details
    alert('View application ' + id);
}

function verifyDocument(id) {
    if (confirm('Verify this document?')) {
        // AJAX to verify document
        alert('Document ' + id + ' verified');
        location.reload(); // Refresh to show updated status
    }
}

function rejectDocument(id) {
    const reason = prompt('Reason for rejection:');
    if (reason) {
        // AJAX to reject document with reason
        alert('Document ' + id + ' rejected');
        location.reload();
    }
}

function makeDecision(id) {
    // Open decision modal or scroll to form
    document.getElementById('admissions-tab').click();
    document.getElementById('decision').focus();
}

document.getElementById('admissionForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const decision = document.getElementById('decision').value;
    const conditions = document.getElementById('conditions').value;

    if (confirm(`Submit ${decision} decision${conditions ? ' with conditions' : ''}?`)) {
        // AJAX to submit decision
        alert('Decision submitted successfully');
        this.reset();
    }
});

// Add loading states and animations
document.addEventListener('DOMContentLoaded', function() {
    // Add fade-in animation to cards
    const cards = document.querySelectorAll('.kpi-card, .chart-card, .card');
    cards.forEach((card, index) => {
        card.style.animationDelay = `${index * 0.1}s`;
        card.classList.add('fade-in');
    });
});
</script>
    </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script>
        // Sidebar toggle functionality
        document.getElementById('sidebar-toggle').addEventListener('click', function() {
            document.getElementById('main-wrapper').classList.toggle('sidebar-collapsed');
        });

        // Close sidebar on mobile when clicking outside
        document.addEventListener('click', function(event) {
            const sidebar = document.getElementById('sidebar');
            const toggle = document.getElementById('sidebar-toggle');
            if (!sidebar.contains(event.target) && !toggle.contains(event.target) && window.innerWidth <= 768) {
                document.getElementById('main-wrapper').classList.remove('sidebar-collapsed');
            }
        });
    </script>
</body>
</html>