<script>
// Enhanced JS for interactions
document.getElementById('programmeFilter').addEventListener('change', function() {
    // AJAX to filter applications
    console.log('Programme filter applied:', this.value);
});

document.getElementById('statusFilter').addEventListener('change', function() {
    // AJAX to filter applications
    console.log('Status filter applied:', this.value);
});

function viewApplication(id) {
    // AJAX to view application details
    alert('View application ' + id);
}

function assignSupervisor(appId) {
    // Open assignment modal or scroll to form
    document.getElementById('assignment-tab').click();
    document.getElementById('application').value = 'APP-2024-' + appId.toString().padStart(3, '0');
    document.getElementById('supervisor').focus();
}

function viewWorkload(supervisorId) {
    // AJAX to view detailed workload
    alert('View workload for supervisor ' + supervisorId);
}

document.getElementById('assignmentForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const application = document.getElementById('application').value;
    const supervisor = document.getElementById('supervisor').value;

    if (confirm(`Assign ${application} to selected supervisor?`)) {
        // AJAX to assign supervisor
        alert('Supervisor assigned successfully');
        this.reset();
    }
});

// Add loading states and animations
document.addEventListener('DOMContentLoaded', function() {
    // Add fade-in animation to cards
    const cards = document.querySelectorAll('.kpi-card, .chart-card, .card');
    cards.forEach((card, index) => {
        card.style.animationDelay = `${index * 0.1}s`;
        card.classList.add('fade-in');
    });
});
</script>
</body>
</html>