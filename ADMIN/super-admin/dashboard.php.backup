<script>
// Enhanced JS for interactions
function editRole(id) {
    // AJAX to edit role
    alert('Edit role for user ' + id);
}

function suspendUser(id) {
    if (confirm('Are you sure you want to suspend this user?')) {
        // AJAX to suspend user
        alert('User ' + id + ' suspended');
    }
}

function viewApplication(id) {
    // Open application details modal or redirect
    alert('View application ' + id);
}

// Add loading states and animations
document.addEventListener('DOMContentLoaded', function() {
    // Add fade-in animation to cards
    const cards = document.querySelectorAll('.kpi-card, .chart-card, .card');
    cards.forEach((card, index) => {
        card.style.animationDelay = `${index * 0.1}s`;
        card.classList.add('fade-in');
    });
});
</script>
</body>
</html>